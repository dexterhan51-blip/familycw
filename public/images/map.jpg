			<script>
				const lazyloadRunObserver = () => {
					const lazyloadBackgrounds = document.querySelectorAll( `.e-con.e-parent:not(.e-lazyloaded)` );
					const lazyloadBackgroundObserver = new IntersectionObserver( ( entries ) => {
						entries.forEach( ( entry ) => {
							if ( entry.isIntersecting ) {
								let lazyloadBackground = entry.target;
								if( lazyloadBackground ) {
									lazyloadBackground.classList.add( 'e-lazyloaded' );
								}
								lazyloadBackgroundObserver.unobserve( entry.target );
							}
						});
					}, { rootMargin: '200px 0px 200px 0px' } );
					lazyloadBackgrounds.forEach( ( lazyloadBackground ) => {
						lazyloadBackgroundObserver.observe( lazyloadBackground );
					} );
				};
				const events = [
					'DOMContentLoaded',
					'elementor/lazyload/observe',
				];
				events.forEach( ( event ) => {
					document.addEventListener( event, lazyloadRunObserver );
				} );
			</script>
			<script>(function () {
  const DEBUG = false;

  // TOC와 byline(“By kimnpartners”) 찾기
  const TOC_SELECTORS = ['#ez-toc-container', '.ez-toc-container', '.ez-toc-widget-container'];

  // 사이트별로 아래 셀렉터를 우선 시도합니다. (필요시 여기에 실제 클래스 추가)
  const BYLINE_CANDIDATES = [
  'a[href*="/author/kimnpartners"]',   // author 링크
  '.cs-meta-author-name',              // ← 여기 추가!
  '.entry-meta', '.post-meta', '.byline',
  '.author-box', '.entry-footer', '.posted-on'
  ];

  const log = (...a)=>{ if(DEBUG) console.log('[TOC]', ...a); };

  function findTOC(){
    for (const s of TOC_SELECTORS){
      const el = document.querySelector(s);
      if (el){ log('found TOC', s, el); return el; }
    }
    return null;
  }

  // “By kimnpartners”가 들어있는 ‘가장 가까운 블록 요소’를 타깃으로
  function findBylineTarget(){
    // 1) author 링크 기준
    const authorLink = document.querySelector(BYLINE_CANDIDATES[0]);
    if (authorLink){
      const box = authorLink.closest('.entry-meta, .post-meta, .byline, .author, .author-box, .entry-footer, article, section, div') || authorLink;
      log('byline by link:', box);
      return box;
    }
    // 2) 일반 메타 박스들 중 “by kimnpartners” 텍스트 포함 확인
    const re = /by\s*kimnpartners/i;
    const nodes = document.querySelectorAll(BYLINE_CANDIDATES.slice(1).join(','));
    for (const el of nodes){
      const t = (el.innerText || '').trim();
      if (t && re.test(t)){ log('byline by text:', el); return el; }
    }
    // 3) 최후: 문서 내에서 텍스트 스캔(가벼운 범위)
    const all = document.querySelectorAll('article, main, .entry-footer, footer, div, section, p, span');
    for (const el of all){
      const t = (el.innerText || '').trim();
      if (t && re.test(t)){ log('byline by scan:', el); return el; }
    }
    return null;
  }

  function hide(toc){ toc.classList.add('ez-toc-hidden'); }
  function show(toc){ toc.classList.remove('ez-toc-hidden'); }

  function attach(toc){
    const target = findBylineTarget();
    if (!target){
      // byline을 못 찾으면 예비 트리거: footer가 보이면 숨김
      const fallback = document.querySelector('footer.site-footer, footer') || document.body;
      observeTarget(fallback, toc);
      log('fallback target (footer/body)');
      return;
    }
    observeTarget(target, toc);
  }

  function observeTarget(target, toc){
    // rootMargin을 0으로: ‘보이기 시작하는 순간’ 즉시 트리거
    if ('IntersectionObserver' in window){
      const io = new IntersectionObserver((entries)=>{
        entries.forEach(e=> e.isIntersecting ? hide(toc) : show(toc));
      }, { root: null, threshold: 0, rootMargin: '0px' });
      io.observe(target);
      // 보조 폴백: 혹시 IO 지원 이슈 대비 (문서 바닥 근접 시)
      const onScroll = ()=>{
        const gap = document.documentElement.scrollHeight - (window.scrollY + window.innerHeight);
        if (gap <= 400) hide(toc);
      };
      window.addEventListener('scroll', onScroll, {passive:true});
      setTimeout(onScroll, 150);
    } else {
      // 아주 구형 브라우저 폴백
      const onScroll = ()=>{
        const r = target.getBoundingClientRect();
        (r.top < window.innerHeight && r.bottom > 0) ? hide(toc) : show(toc);
      };
      window.addEventListener('scroll', onScroll, {passive:true});
      window.addEventListener('resize', onScroll);
      onScroll();
    }
  }

  function boot(){
    const tryInit = ()=>{
      const toc = findTOC();
      if (!toc) return false;
      attach(toc);
      return true;
    };

    if (tryInit()) return;

    // 지연 로딩/동적 삽입 대비
    const mo = new MutationObserver(()=>{ if (tryInit()) mo.disconnect(); });
    mo.observe(document.documentElement, { childList:true, subtree:true });
    window.addEventListener('load', ()=> setTimeout(tryInit, 300));
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
  else boot();
})();
</script><script id="ez-toc-scroll-scriptjs-js-extra">
